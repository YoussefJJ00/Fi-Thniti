{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@components/*": ["components/*"],
      "@components/ui/*": ["components/ui/*"]
    },
    "baseUrl": "src"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
