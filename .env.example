# ================================================
# Fi'Thniti - Environment Variables Template
# ================================================
# 
# NOTE: This file is OPTIONAL for running the app.
# The app currently has API keys hardcoded in:
#   - firebaseConfig.js (Firebase credentials)
#   - MapScreen.js (Google Maps/Places keys)
#   - app.json (Expo native config)
#
# HOWEVER, for SECURITY, it is HIGHLY RECOMMENDED to:
# 1. Copy this file to .env
# 2. Fill in your actual credentials
# 3. Modify the source files to use these variables
# 4. Add .env to .gitignore (NEVER commit secrets!)
#
# ================================================

# ================================================
# FIREBASE CONFIGURATION
# ================================================
# Get these from Firebase Console > Project Settings > General
# Copy the "Web" config from "Your apps" section
#
FIREBASE_API_KEY=AIza...your_firebase_api_key...
FIREBASE_AUTH_DOMAIN=fi-thniti-xxx.firebaseapp.com
FIREBASE_PROJECT_ID=fi-thniti-xxx
FIREBASE_STORAGE_BUCKET=fi-thniti-xxx.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789...
FIREBASE_APP_ID=1:123456789:web:abc123...
FIREBASE_DATABASE_URL=https://fi-thniti-xxx.firebaseio.com

# ================================================
# GOOGLE MAPS & PLACES CONFIGURATION
# ================================================
# Get these from Google Cloud Console > Credentials
# Enable APIs: Maps SDK, Places API, Directions API, Geocoding API
#
GOOGLE_MAPS_API_KEY=AIzaSyD_...your_google_maps_key...
GOOGLE_PLACES_API_KEY=AIzaSyD_...your_google_places_key...
GOOGLE_DIRECTIONS_API_KEY=AIzaSyD_...your_google_directions_key...

# ================================================
# EXTERNAL API KEYS
# ================================================
# API Ninjas - Used for vehicle brand/model lookup
# Get free API key from: https://api-ninjas.com
#
API_NINJAS_KEY=your_api_ninjas_key_here

# NHTSA VPIC - Free service for vehicle lookup
# (No key required - public API)
# URL: https://vpic.nhtsa.dot.gov/api/

# ================================================
# APPLICATION CONFIGURATION
# ================================================
# Environment mode (development, staging, production)
EXPO_PUBLIC_APP_ENV=development

# App name (displayed in app)
EXPO_PUBLIC_APP_NAME=Fi'Thniti

# API base URL (if you have a backend)
# For development: http://localhost:3000
# For production: https://api.fithniti.tn
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# ================================================
# FEATURE FLAGS (Optional)
# ================================================
# Enable/disable features for testing
EXPO_PUBLIC_ENABLE_ADMIN_PANEL=false
EXPO_PUBLIC_ENABLE_RIDE_RATINGS=true
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=false

# ================================================
# PAYMENT CONFIGURATION (Optional - Future)
# ================================================
# If implementing payment processing later
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# ================================================
# IMPORTANT SECURITY NOTES
# ================================================
# 
# 1. Variables prefixed with EXPO_PUBLIC_ are accessible on the client side.
#    Use only for keys that have client-side API restrictions in Google Cloud.
#    Example: GOOGLE_MAPS_API_KEY can be restricted to your app's package name.
#
# 2. Variables WITHOUT EXPO_PUBLIC_ prefix are private.
#    Use for backend-only secrets (if you build a backend).
#    Example: FIREBASE_DATABASE_URL (backend connection string)
#
# 3. NEVER commit this file with real values to Git!
#    Always use: .gitignore containing ".env*"
#
# 4. For production deployment:
#    - Use EAS Secrets: eas secret:create FIREBASE_API_KEY
#    - Reference in eas.json under build.production.env
#    - Or use your deployment platform's secret manager
#
# 5. Rotate API keys periodically (every 6-12 months recommended)
#
# ================================================

# ================================================
# HOW TO USE THIS FILE
# ================================================
#
# Step 1: Copy this file
#   cp .env.example .env
#
# Step 2: Fill in your credentials
#   nano .env  (or your preferred editor)
#
# Step 3: Modify source files to read from .env
#   
#   Example: firebaseConfig.js
#   Before:
#     const firebaseConfig = { apiKey: "hardcoded_value", ... };
#   
#   After:
#     import Constants from 'expo-constants';
#     const firebaseConfig = {
#       apiKey: Constants.expoConfig?.extra?.firebaseApiKey,
#       // ...
#     };
#
# Step 4: Update app.json
#   {
#     "expo": {
#       "extra": {
#         "firebaseApiKey": "${FIREBASE_API_KEY}",
#         "googleMapsApiKey": "${GOOGLE_MAPS_API_KEY}",
#         // ...
#       }
#     }
#   }
#
# Step 5: Ensure .gitignore has .env
#   .env
#   .env.local
#   .env.production
#
# ================================================

# ================================================
# ENVIRONMENT-SPECIFIC EXAMPLES
# ================================================
#
# For Development:
#   EXPO_PUBLIC_APP_ENV=development
#   FIREBASE_PROJECT_ID=fi-thniti-dev
#   GOOGLE_MAPS_API_KEY=your_dev_key
#
# For Staging:
#   EXPO_PUBLIC_APP_ENV=staging
#   FIREBASE_PROJECT_ID=fi-thniti-staging
#   GOOGLE_MAPS_API_KEY=your_staging_key
#
# For Production:
#   EXPO_PUBLIC_APP_ENV=production
#   FIREBASE_PROJECT_ID=fi-thniti-prod
#   GOOGLE_MAPS_API_KEY=your_prod_key
#   STRIPE_PUBLIC_KEY=pk_live_...
#
# ================================================
